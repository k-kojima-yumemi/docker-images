{
  "name": "hono-otel-template",
  "type": "module",
  "scripts": {
    "format": "biome check --write --unsafe",
    "ci": "biome ci && tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.cjs --external:@opentelemetry/* --external:@hono/standard-validator --external:@standard-community/*",
    "test": "vitest run"
  },
  "volta": {
    "node": "24.15.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@hono/standard-validator": "^0.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@valibot/to-json-schema": "^1.6.0",
    "hono": "^4.12.10",
    "hono-openapi": "^1.3.0",
    "valibot": "^1.3.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  }
}
